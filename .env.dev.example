# ==========================================================
# Local Development Environment (.env.dev)
# ==========================================================
# Copy this file to .env.dev and adjust values as needed.
# Used for running:
#   - Postgres/Redis/WuKongIM inside Docker
#   - Backend/frontend services directly on host with hot reload
# ==========================================================

ENVIRONMENT=development
DEBUG=true
SERVER_HOST=127.0.0.1

# ==========================================================
# Database
# ==========================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tgo
POSTGRES_USER=tgo
POSTGRES_PASSWORD=tgo
DATABASE_URL=postgresql+asyncpg://tgo:tgo@localhost:5432/tgo

# ==========================================================
# Redis
# ==========================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ==========================================================
# Service Ports
# ==========================================================
TGO_API_PORT=8000
TGO_PLATFORM_PORT=8003
TGO_WEB_PORT=5173
TGO_WIDGET_PORT=5174

# ==========================================================
# Internal Service URLs
# ==========================================================
API_SERVICE_URL=http://localhost:${TGO_API_PORT}
PLATFORM_SERVICE_URL=http://localhost:${TGO_PLATFORM_PORT}
WUKONGIM_SERVICE_URL=http://localhost:5001
WUKONGIM_ENABLED=true
WK_EXTERNAL_IP=127.0.0.1

# ==========================================================
# Frontend Environment Variables
# ==========================================================
VITE_API_BASE_URL=http://localhost:${TGO_API_PORT}
VITE_WIDGET_PREVIEW_URL=http://localhost:${TGO_WIDGET_PORT}
VITE_WIDGET_SCRIPT_BASE=http://localhost:${TGO_WIDGET_PORT}/tgo-widget-sdk.js
VITE_WIDGET_DEMO_URL=http://localhost:${TGO_WIDGET_PORT}/demo.html
VITE_DEBUG_MODE=true

# ==========================================================
# AI Provider (FastGPT)
# ==========================================================
AI_PROVIDER_MODE=fastgpt
FASTGPT_API_BASE=https://api.fastgpt.cloud
FASTGPT_API_KEY=replace-me
FASTGPT_MODEL=gpt-4o-mini
FASTGPT_TIMEOUT=60
FASTGPT_COMPLETIONS_PATH=/api/openapi/v1/chat/completions

# ==========================================================
# Security & Logging
# ==========================================================
SECRET_KEY=dev_secret_key_change_in_production_12345678901234567890
ACCESS_TOKEN_EXPIRE_MINUTES=10080
STORAGE_TYPE=local
LOG_LEVEL=DEBUG
