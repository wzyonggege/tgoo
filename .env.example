# ============================================================
# Core Service Configuration
# ============================================================

ENVIRONMENT=production
SERVER_HOST=127.0.0.1

# PostgreSQL
POSTGRES_DB=tgo
POSTGRES_USER=tgo
POSTGRES_PASSWORD=tgo
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Internal container ports (used by docker-compose)
API_PORT=8000
PLATFORM_PORT=8003
WEB_PORT=3000
WIDGET_PORT=3001

# ============================================================
# Public Entry (Nginx + Frontend)
# ============================================================
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_CLIENT_MAX_BODY_SIZE=100m

# Optional domain settings
WEB_DOMAIN=
WIDGET_DOMAIN=
API_DOMAIN=
SSL_MODE=none          # none | auto | manual
SSL_EMAIL=
ENABLE_SSL_AUTO_RENEW=true

# Frontend build/runtime variables (consumed by Vite apps)
VITE_WIDGET_PREVIEW_URL=/widget/
VITE_WIDGET_SCRIPT_BASE=/widget/tgo-widget-sdk.js
VITE_WIDGET_DEMO_URL=/widget/demo.html
VITE_API_BASE_URL=/api
VITE_DEBUG_MODE=false

# ============================================================
# Messaging (WuKongIM)
# ============================================================
WK_EXTERNAL_IP=
WK_EXTERNAL_TCPADDR=
WK_EXTERNAL_WSADDR=
WK_EXTERNAL_WSSADDR=

# ============================================================
# AI Provider (FastGPT by default)
# ============================================================
AI_PROVIDER_MODE=fastgpt
FASTGPT_API_BASE=https://api.fastgpt.cloud
FASTGPT_API_KEY=
FASTGPT_MODEL=gpt-4o-mini
FASTGPT_TIMEOUT=60
FASTGPT_COMPLETIONS_PATH=/api/openapi/v1/chat/completions

# ============================================================
# Store (optional SaaS integration)
# ============================================================
STORE_SERVICE_URL=https://store.tgo.ai
STORE_WEB_URL=https://store.tgo.ai

# ============================================================
# Storage Configuration
# ============================================================
STORAGE_TYPE=local      # local | oss | minio
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET_NAME=your-bucket-name
# OSS_BUCKET_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# MINIO_URL=http://your-minio-host:9000
# MINIO_ACCESS_KEY_ID=your-access-key-id
# MINIO_SECRET_ACCESS_KEY=your-secret-access-key
# MINIO_BUCKET_NAME=your-bucket-name
# MINIO_UPLOAD_URL=http://internal-minio:9000
# MINIO_DOWNLOAD_URL=https://public-minio-domain.com

# ============================================================
# SMTP (optional)
# ============================================================
# TGO_SMTP_HOST=smtp.example.com
# TGO_SMTP_PORT=587
# TGO_SMTP_USERNAME=your-username
# TGO_SMTP_PASSWORD=your-password
# TGO_SMTP_USE_TLS=true
# TGO_SMTP_FROM_ADDRESS=noreply@example.com

# ============================================================
# Advanced Settings
# ============================================================
# ACCESS_TOKEN_EXPIRE_MINUTES=43200
# MAX_UPLOAD_SIZE_MB=20
# LOG_LEVEL=INFO

